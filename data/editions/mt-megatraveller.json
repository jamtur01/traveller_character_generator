  "edition": {
    "id": "mt-megatraveller",
    "name": "MegaTraveller",
    "displayName": "MegaTraveller",
    "rulebooks": ["MegaTraveller Players' Manual"],
    "year": 1987,
    "status": "active",
    "source": "Extracted from https://traveller.chromeblack.com/files/mtpcgen.html (mtpcgen.html JS data tables)."
  },
  "title": "MegaTraveller basic character generation data",
  "extractionNotes": [
    "Extracted from the JavaScript data tables embedded in mtpcgen.html.",
    "DM convention: 'X+' attribute condition means DM applies if attribute >= X; 'X-' means <= X. DM1 grants +1 effective, DM2 grants +2.",
    "Cell labels marked 'Physical', 'Mental', 'Vice', 'Hand Combat', 'Vehicle', 'Inborn', 'Space', 'Space Combat', 'Space Tech', 'Special Combat', 'Technical', 'Interpersonal', 'Science', 'Academic', 'Exploratory', 'Environ', 'Economic', 'Archaic Weapons', 'Aircraft' are MT cascade skills — players normally choose, the generator picks one at random from the pool listed under cascadeSkills.",
    "Benefit labels 'Weapon' = pick a blade or gun; 'Letter' = Letter of Marque (Pirate-specific); 'Trader' = Free Trader; '-1 Social' = social loss (Pirate-specific bnLoseSoc); 'Forensic Kit' = Law Enforcer specialty.",
    "MT mechanics not yet expressible in the CT-shaped schema (lifecycle.mtExtensions documents the diffs):",
    "  - Special Duty roll: a fifth per-term roll giving 1 or 2 bonus skills (4+ over target = 2 bonuses).",
    "  - Commission and Promotion overshoot: rolling target+4 or higher grants 2 bonus skills instead of 1.",
    "  - First term: characters with skillsPerTerm=1 receive +1 extra skill in term 1 only.",
    "  - Belter automatic Zero-G Environ at start of term 3.",
    "  - Homeworld step before career selection (UPP from 2d6, then world tech/pop/etc.; tech tier determines available careers and gates a homeworld-skill grant).",
    "  - Reenlistment: rolling exactly 12 mandates another term (mandatoryOnExactRoll = 12)."
  ],
  "sources": {
    "mt": {
      "title": "MegaTraveller Basic Character Generator",
      "file": "mtpcgen.html",
      "characterGenerationPages": []
    }
  },
  "attributes": [
    { "key": "strength", "label": "Strength", "uppPosition": 1, "initialRoll": "2d6" },
    { "key": "dexterity", "label": "Dexterity", "uppPosition": 2, "initialRoll": "2d6" },
    { "key": "endurance", "label": "Endurance", "uppPosition": 3, "initialRoll": "2d6" },
    { "key": "intelligence", "label": "Intelligence", "uppPosition": 4, "initialRoll": "2d6" },
    { "key": "education", "label": "Education", "uppPosition": 5, "initialRoll": "2d6" },
    { "key": "social", "label": "Social Standing", "uppPosition": 6, "initialRoll": "2d6" }
  ],
  "lifecycle": {
    "terms": [
      { "id": "allocateSkills", "config": { "term1Bonus": true } },
      { "id": "survival" },
      { "id": "commission", "config": { "doubleBonusOvershoot": 4 } },
      { "id": "promotion", "config": { "doubleBonusOvershoot": 4 } },
      { "id": "specialDuty", "config": { "doubleBonusOvershoot": 4 } }
    ],
    "mtChecklist": [
      { "step": 1, "id": "rollCharacteristics", "uses": ["attributes"] },
      { "step": 2, "id": "rollHomeworld", "uses": ["mtExtensions.homeworld"] },
      { "step": 3, "id": "selectCareerAndEnlist", "uses": ["services.*.checks.enlistment"] },
      { "step": "3A", "id": "draftIfRejected", "uses": ["services.*.draft"] },
      { "step": "3B", "id": "survival", "uses": ["services.*.checks.survival"] },
      { "step": "3C1", "id": "commission", "uses": ["services.*.checks.position"] },
      { "step": "3C2", "id": "promotion", "uses": ["services.*.checks.promotion"] },
      { "step": "3C3", "id": "specialDuty", "uses": ["services.*.checks.specialDuty"] },
      { "step": "3D1", "id": "automaticSkills", "uses": ["services.*.automaticSkills"] },
      { "step": "3D2", "id": "acquiredSkills", "uses": ["services.*.skillTables", "services.*.skillsPerTerm", "mtExtensions.term1Bonus"] },
      { "step": "3D3", "id": "cascadeSkills", "uses": ["cascadeSkills"] },
      { "step": "3E", "id": "aging", "uses": ["aging"] },
      { "step": "3F", "id": "reenlistment", "uses": ["services.*.checks.reenlistment", "mtExtensions.mandatoryReenlistOn12"] },
      { "step": 4, "id": "musterOut", "uses": ["services.*.musterOut"] }
    ],
    "mtExtensions": {
      "homeworld": "Generate homeworld (Starport/Size/Atmos/Hydro/Pop/Law/Tech). Tech>=7 grants Computer-0; Tech 3-8 grants Wheeled Vehicle-0; Tech>=9 grants Grav Vehicle-0. Tech<5 hides Army/Marines/Navy/Scientist/Noble. Tech<7 hides Scout/Merchant/Belter/Pirate. Tech<3 hides Flyer/Law Enforcer/Doctor/Diplomat/Rogue. Tech>=3 hides Barbarian. Soc<10 hides Noble.",
      "term1Bonus": "Careers with skillsPerTerm=1 receive +1 additional skill in term 1.",
      "specialDutyDoubleBonus": "Special Duty roll 4+ over target grants 2 skills instead of 1.",
      "commissionPromotionDoubleBonus": "Commission or Promotion roll 4+ over target grants 2 bonus skills instead of 1.",
      "mandatoryReenlistOn12": "Rolling exactly 12 on reenlistment forces another term.",
      "belterTerm3ZeroG": "Belter automatically gains Zero-G Environ-1 at start of term 3."
    }
  },
  "rules": {
