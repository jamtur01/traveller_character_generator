# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/docs

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Source rulebook PDFs used only for local audit work, never to be committed.
# (Classic Traveller PDFs are copyrighted; only the player owning a licensed
# copy may have them locally.)
*.pdf

# Exception: the official Mongoose Traveller fillable character sheet is a
# runtime asset (fetched from /public to render Mongoose characters) and is
# licensed for online use, so it is tracked despite the *.pdf rule above.
!public/mongoose-character-sheet.pdf

# Local agent state (Claude Code scheduled tasks, etc.)
/.claude/

# Agent harness memory/state store (accidentally committed once; never track)
/data/state_store.db/
/stream_store/

# Local PDF-extraction references + rendered page scans (derived from the
# copyrighted rulebooks; audit aids only, not tracked). Also keeps ~120MB of
# rendered PNGs out of git history.
/reference/
